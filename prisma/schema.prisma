generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  SUPERVISOR
  AGENT
}

enum ConversationStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum SenderType {
  USER
  AGENT
  SYSTEM
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  DOCUMENT
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  role          UserRole       @default(AGENT)
  createdAt     DateTime       @default(now())
  userChannels  UserChannel[]
  conversations Conversation[]
  notes         InternalNote[]
}

model Channel {
  id                String         @id @default(cuid())
  name              String
  phoneNumber       String
  isActive          Boolean        @default(true)
  createdAt         DateTime       @default(now())
  
  provider          String?        @default("EVOLUTION")
  providerSessionId String?        @unique
  connectionStatus  String?        @default("DISCONNECTED")

  userChannels       UserChannel[]
  conversations      Conversation[]
  messages           Message[]
  quickReplies       QuickReply[]
  keywordSuggestions KeywordSuggestion[]
}

model UserChannel {
  userId    String
  channelId String
  user      User    @relation(fields: [userId], references: [id])
  channel   Channel @relation(fields: [channelId], references: [id])

  @@id([userId, channelId])
}

model Contact {
  id            String         @id @default(cuid())
  name          String
  phone         String         @unique
  createdAt     DateTime       @default(now())
  conversations Conversation[]
}

model Conversation {
  id          String             @id @default(cuid())
  contactId   String
  channelId   String
  assignedTo  String?
  status      ConversationStatus @default(OPEN)
  createdAt   DateTime           @default(now())
  contact     Contact            @relation(fields: [contactId], references: [id])
  channel     Channel            @relation(fields: [channelId], references: [id])
  agent       User?              @relation(fields: [assignedTo], references: [id])
  messages    Message[]
  tags        ConversationTag[]
  notes       InternalNote[]
  lastMessageAt DateTime @default(now())
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  channelId      String
  senderType     SenderType
  content        String
  type           MessageType  @default(TEXT)
  createdAt      DateTime     @default(now())
  externalMessageId String?   @unique
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  channel        Channel      @relation(fields: [channelId], references: [id])
}

model Tag {
  id            String            @id @default(cuid())
  name          String            @unique
  emoji         String?           @default("🏷️")
  color         String            @default("#3b82f6")
  conversations ConversationTag[]
}

model ConversationTag {
  conversationId String
  tagId          String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  tag            Tag          @relation(fields: [tagId], references: [id])

  @@id([conversationId, tagId])
}

model QuickReply {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String
  channelId String?
  createdAt DateTime @default(now())
  channel   Channel? @relation(fields: [channelId], references: [id])
}

model KeywordSuggestion {
  id        String   @id @default(cuid())
  keyword   String
  triggers  String[] // Array de strings (compatível com PostgreSQL)
  response  String
  category  String
  channelId String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  channel   Channel? @relation(fields: [channelId], references: [id])
}

model InternalNote {
  id             String       @id @default(cuid())
  conversationId String
  content        String
  createdBy      String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  user           User         @relation(fields: [createdBy], references: [id])
}
